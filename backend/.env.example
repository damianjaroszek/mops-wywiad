# ============================================================
# KONFIGURACJA BACKENDU — skopiuj do .env i uzupełnij wartości
# NIGDY nie commituj pliku .env na GitHub!
# ============================================================

# Supabase (Settings → API)
SUPABASE_URL=https://TWOJ_PROJEKT.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9_SERVICE_ROLE_KEY_HERE

# Anthropic Claude (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-api03-TUTAJ_WKLEJ_KLUCZ

# OpenAI — tylko do embeddingów RAG (platform.openai.com → API Keys)
OPENAI_API_KEY=sk-proj-TUTAJ_WKLEJ_KLUCZ

# Bezpieczeństwo — wygeneruj: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TUTAJ_WKLEJ_LOSOWY_STRING_MIN_32_ZNAKI

# CORS — dozwolone originy (oddzielone przecinkami, bez spacji)
# Lokalnie: dodaj swoje IP (ipconfig → "Adres IPv4")
# Produkcja: dodaj URL Render.com
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000,http://192.168.1.100:8081

# Środowisko
ENVIRONMENT=development
LOG_LEVEL=INFO
