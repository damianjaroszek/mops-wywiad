{
  "expo": {
    "name": "MOPS Wywiad",
    "slug": "mops-wywiad",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1565C0"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1565C0"
      },
      "package": "pl.mops.wywiad"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pl.mops.wywiad"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1565C0",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-font"
    ],
    "scheme": "mops-wywiad",
    "experiments": {
      "typedRoutes": true
    }
  }
}
